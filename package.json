{
  "name": "@baoyu/markdown-to-html",
  "version": "1.0.0",
  "description": "Convert Markdown to styled HTML with WeChat-compatible themes, code highlighting, Mermaid diagrams, and --watch mode",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./core": "./core.ts",
    "./types": "./types.ts",
    "./constants": "./constants.ts",
    "./utils": "./utils.ts",
    "./cli": "./cli.ts",
    "./metadata": "./metadata.ts"
  },
  "bin": {
    "md2html": "./main.ts"
  },
  "scripts": {
    "start": "bun main.ts",
    "dev": "bun --watch main.ts",
    "build": "bun build --outdir=dist main.ts",
    "preview": "bun main.ts example.md --theme grace --color blue",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "baoyu-md": "^0.1.1",
    "baoyu-chrome-cdp": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "*.ts",
    "package.json",
    "README.md",
    "SKILL.md"
  ],
  "keywords": [
    "markdown",
    "html",
    "wechat",
    "blog",
    "publishing",
    "mermaid"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/<your-username>/markdown-to-html"
  },
  "publishConfig": {
    "access": "public"
  }
}
